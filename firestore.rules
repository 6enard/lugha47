rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /languages/{languageId} {
      allow read: if true;
      allow write: if true;
    }

    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if true;
    }

    match /lessonContent/{contentId} {
      allow read: if true;
      allow write: if true;
    }

    match /quizQuestions/{questionId} {
      allow read: if true;
      allow write: if true;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /languages/{languageId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /progress/{progressId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /quizResults/{resultId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
